{
  "name": "unlocked",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "validate:data": "node scripts/validate-data.mjs",
    "check:onboarding": "node scripts/check-onboarding-flow.mjs",
    "check:advisor": "node scripts/check-advisor-brain.mjs && node scripts/check-advisor-quality.mjs",
    "check:auth": "node scripts/check-auth-query.mjs",
    "check:profile-flow": "node scripts/check-advisor-profile-flow.mjs",
    "check:interview": "node scripts/check-interview-intelligence.mjs",
    "check:advisor-ux": "node scripts/check-advisor-ux-integration.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "check:performance": "node scripts/check-performance-regressions.mjs",
    "check:journey-board": "node scripts/check-journey-board.mjs",
    "prebuild": "npm run validate:data && npm run check:onboarding && npm run check:advisor && npm run check:auth && npm run check:profile-flow && npm run check:interview && npm run check:advisor-ux && npm run check:performance && npm run check:journey-board",
    "build": "next build",
    "postbuild": "node scripts/verify-homepage-build.mjs",
    "start": "next start",
    "lint": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "20.14.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.40",
    "tailwindcss": "3.4.7",
    "typescript": "5.5.4"
  }
}
