{
  "name": "unlocked",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "validate:data": "node scripts/validate-data.mjs",
    "check:data-enrichment": "node scripts/check-opportunity-enrichment.mjs",
    "check:national-opportunities": "node scripts/check-national-opportunities.mjs",
    "check:opportunity-verification": "node scripts/check-opportunity-verification.mjs",
    "check:school-eligibility": "node scripts/check-school-eligibility.mjs",
    "check:national-links": "node scripts/check-national-links.mjs",
    "check:build-performance": "node scripts/check-build-performance.mjs",
    "check:billing": "node scripts/check-billing.mjs",
    "check:onboarding": "node scripts/check-onboarding-flow.mjs",
    "check:advisor": "node scripts/check-advisor-brain.mjs && node scripts/check-advisor-quality.mjs && node scripts/check-recommendation-engine.mjs && node scripts/check-recommendation-engine-v2.mjs",
    "check:advisor-v3": "node scripts/check-advisor-engine-v3.mjs",
    "check:professional-recommendations": "node --no-warnings --loader ./scripts/ts-test-loader.mjs scripts/check-professional-recommendations.ts",
    "check:professional-recommendations:quick": "node --no-warnings --loader ./scripts/ts-test-loader.mjs scripts/check-professional-recommendations.ts --quick",
    "check:professional-catalog": "node scripts/check-professional-catalog.mjs",
    "check:recommendation-engine-v2": "node scripts/check-recommendation-engine-v2.mjs",
    "check:auth": "node scripts/check-auth-query.mjs",
    "check:profile-flow": "node scripts/check-advisor-profile-flow.mjs",
    "check:interview": "node scripts/check-interview-intelligence.mjs",
    "check:advisor-ux": "node scripts/check-advisor-ux-integration.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "check:performance": "node scripts/check-performance-regressions.mjs",
    "check:journey-board": "node scripts/check-journey-board.mjs",
    "check:college-journey": "node scripts/check-college-journey.mjs",
    "check:discover": "node scripts/check-discover-redesign.mjs",
    "check:journey-redesign": "node scripts/check-journey-redesign.mjs",
    "check:for-you": "node scripts/check-for-you-redesign.mjs && node scripts/check-for-you-client-contract.mjs",
    "check:for-you-reliability": "node scripts/check-for-you-reliability.mjs",
    "check:for-you-first-request": "node scripts/check-for-you-first-request.mjs",
    "check:logos": "node scripts/check-organization-logos.mjs",
    "check:referrals": "node scripts/check-referrals.mjs",
    "check:release-candidate": "node scripts/check-release-candidate.mjs",
    "audit:logos": "node scripts/audit-organization-logos.mjs",
    "diagnose:logos": "node scripts/diagnose-organization-logos.mjs",
    "prebuild": "npm run validate:data && npm run check:data-enrichment && npm run check:national-opportunities && npm run check:opportunity-verification && npm run check:professional-catalog && npm run check:school-eligibility && npm run check:national-links && npm run check:build-performance && npm run check:billing && npm run check:onboarding && npm run check:advisor && npm run check:advisor-v3 && npm run check:professional-recommendations:quick && npm run check:auth && npm run check:profile-flow && npm run check:interview && npm run check:advisor-ux && npm run check:performance && npm run check:journey-board && npm run check:college-journey && npm run check:discover && npm run check:journey-redesign && npm run check:for-you && npm run check:for-you-reliability && npm run check:for-you-first-request && npm run check:logos && npm run check:referrals && npm run check:release-candidate",
    "build": "next build",
    "postbuild": "node scripts/verify-homepage-build.mjs",
    "start": "next start",
    "lint": "tsc --noEmit --pretty false"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "20.14.12",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.40",
    "tailwindcss": "3.4.7",
    "typescript": "5.5.4"
  }
}
